{
  "version": 2,
  "installCommand": "pip install -r requirements.txt && cd updatedDesign && npm ci",
  "buildCommand": "bash scripts/build-spa.sh",
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.py"
    }
  ]
}
